{
  "name": "@feralcaraz/project-memory-mcp",
  "version": "0.2.0",
  "description": "A neutral context layer for AI coding tools. MCP server that exposes structured, curated project context to any MCP-compatible client.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "project-memory-mcp": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "benchmark:tokens": "npm run build && node scripts/benchmark-tokens.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-desktop",
    "claude-code",
    "cursor",
    "anthropic",
    "ai",
    "ai-tools",
    "ai-agents",
    "developer-tools",
    "context",
    "persistent-memory",
    "agent-memory",
    "llm-tools"
  ],
  "author": "Fernando Alcaraz",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "simple-git": "^3.25.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "gpt-tokenizer": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
